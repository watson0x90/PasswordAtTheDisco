{
  "_comment": "Application configuration for Password!AtTheDisco",

  "server": {
    "_description": "Web server settings for serving HTML reports",
    "port": 8008,
    "host": "localhost"
  },

  "ui": {
    "_description": "User interface settings",
    "enable_animation": true
  },

  "reports": {
    "_description": "Report generation settings",
    "_enable_static_charts": "Render static PNG charts (plotly+kaleido) for Markdown/PDF reports. HTML reports embed interactive charts and do not need this. OFF by default: kaleido 0.2.1 can hang on some platforms (e.g. Windows).",
    "enable_static_charts": false
  }
}
