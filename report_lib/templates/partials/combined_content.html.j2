{# Cross-domain combined report body. All interpolated values are pre-rendered
   trusted fragments (metric cards, top-shared table macro, visualisations,
   sharing section, offcanvas, scripts). #}
{{ breadcrumb_html | safe }}

<div class="mb-4">
    <h1 class="display-4"><i class="bi bi-diagram-3 me-3"></i>Cross-Domain Analysis</h1>
    <p class="lead text-muted">Shared credentials and lateral movement risks</p>
</div>
{{ metrics_error_html | safe }}
<h2 class="mb-4"><i class="bi bi-bar-chart me-2"></i>Overview</h2>
<div class="row g-4 mb-4">
    <div class="col-12 col-md-6">{{ card1_html | safe }}</div>
    <div class="col-12 col-md-6">{{ card2_html | safe }}</div>
</div>
{% if total_shared == 0 %}<div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>No cross-domain sharing detected.</div>{% endif %}
{{ top_shared_html | safe }}
{{ viz_html | safe }}
{{ sharing_section_html | safe }}
{{ offcanvas_html | safe }}

{{ scripts_html | safe }}
