{# Collapsible sidebar navigation. Context: current_page (str), domains (list).
   Domain names are autoescaped (they are AD-derived). #}
<!-- Collapsible Sidebar -->
<div class="sidebar sidebar-fixed" id="sidebar" role="navigation" aria-label="Primary">
    <ul class="sidebar-nav" data-coreui="navigation" data-simplebar>

        <!-- Dashboard -->
        <li class="nav-item">
            <a class="nav-link {{ 'active' if current_page == 'dashboard' else '' }}"{% if current_page == 'dashboard' %} aria-current="page"{% endif %} href="main.html">
                <i class="bi bi-house-door nav-icon" aria-hidden="true"></i><span>Dashboard</span>
            </a>
        </li>

        <!-- Executive Summary -->
        <li class="nav-item">
            <a class="nav-link {{ 'active' if current_page == 'executive' else '' }}"{% if current_page == 'executive' %} aria-current="page"{% endif %} href="executive_summary.html">
                <i class="bi bi-clipboard-data nav-icon" aria-hidden="true"></i><span>Executive Summary</span>
            </a>
        </li>

        <li class="nav-divider"></li>

        <!-- Domains Section -->
        <li class="nav-title">Analysis</li>

        {% if domains %}
        {% for domain in domains %}
        <li class="nav-group">
            <a class="nav-link nav-group-toggle" href="#" aria-expanded="false">
                <i class="bi bi-building nav-icon" aria-hidden="true"></i><span>{{ domain }}</span>
            </a>
            <ul class="nav-group-items compact">
                <li class="nav-item">
                    <a class="nav-link" href="{{ domain }}_actionable_report.html">
                        <i class="bi bi-clipboard-check me-2" aria-hidden="true"></i>Actionable Report
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ domain }}_report.html">
                        <i class="bi bi-file-earmark-text me-2" aria-hidden="true"></i>Full Report
                    </a>
                </li>
                <li class="nav-group">
                    <a class="nav-link nav-group-toggle" href="#" aria-expanded="false">
                        <i class="bi bi-bar-chart me-2" aria-hidden="true"></i>Visualizations
                    </a>
                    <ul class="nav-group-items compact">
                        <li class="nav-item"><a class="nav-link" href="{{ domain }}_risk_levels.html">Risk Distribution</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ domain }}_complexity_distribution.html">Complexity Analysis</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ domain }}_hibp_breach_distribution.html">HIBP Correlation</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ domain }}_score_breakdown.html">Score Breakdown</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ domain }}_da_risk.html">DA Pathways</a></li>
                    </ul>
                </li>
            </ul>
        </li>
        {% endfor %}
        {% else %}
        <li class="nav-item"><span class="nav-link text-muted"><i>No domains loaded</i></span></li>
        {% endif %}

        <li class="nav-divider"></li>

        <!-- Search -->
        <li class="nav-title">Tools</li>
        <li class="nav-group">
            <a class="nav-link nav-group-toggle {{ 'active' if current_page == 'search' else '' }}" href="#" aria-expanded="false">
                <i class="bi bi-search nav-icon" aria-hidden="true"></i>
                Search
            </a>
            <ul class="nav-group-items compact">
                <li class="nav-item">
                    <a class="nav-link" href="search.html">
                        <i class="bi bi-search me-2" aria-hidden="true"></i>Account Search
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="search_redacted.html">
                        <i class="bi bi-eye-slash me-2" aria-hidden="true"></i>Redacted Search
                    </a>
                </li>
            </ul>
        </li>

        <!-- Cross-Domain Analysis -->
        <li class="nav-group">
            <a class="nav-link nav-group-toggle {{ 'active' if current_page == 'cross-domain' else '' }}" href="#" aria-expanded="false">
                <i class="bi bi-diagram-3 nav-icon" aria-hidden="true"></i>
                Cross-Domain
            </a>
            <ul class="nav-group-items compact">
                <li class="nav-item">
                    <a class="nav-link" href="combined_report.html">
                        <i class="bi bi-file-earmark-bar-graph me-2" aria-hidden="true"></i>Combined Report
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="combined_shared_network.html">
                        <i class="bi bi-share me-2" aria-hidden="true"></i>Password Sharing
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="combined_top_shared_hashes.html">
                        <i class="bi bi-hash me-2" aria-hidden="true"></i>Hash Sharing
                    </a>
                </li>
            </ul>
        </li>

        <li class="nav-divider"></li>

        <!-- About -->
        <li class="nav-item">
            <a class="nav-link {{ 'active' if current_page == 'about' else '' }}"{% if current_page == 'about' %} aria-current="page"{% endif %} href="about.html">
                <i class="bi bi-info-circle nav-icon" aria-hidden="true"></i><span>About</span>
            </a>
        </li>

    </ul>
</div>
