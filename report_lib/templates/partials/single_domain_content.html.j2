{# Per-domain report body. Computed values are autoescaped; pre-rendered helper
   fragments (overview, risk list, viz, DA table, offcanvas, scripts) are trusted
   and passed through | safe. Reproduces the create_bootstrap_card structure for
   the Risk Distribution and BloodHound cards. #}
{{ breadcrumb_html | safe }}

<div class="mb-4">
    <h1 class="display-4"><i class="bi bi-shield-lock me-3"></i>Password Security Report</h1>
    <p class="lead text-muted">{{ domain }}</p>
</div>
{{ counts_error_html | safe }}
<h2 class="mb-4"><i class="bi bi-bar-chart me-2"></i>Overview</h2>
{{ overview_html | safe }}
{% if has_hibp %}
<div class="alert alert-danger" role="alert">
    <h5 class="alert-heading"><i class="bi bi-exclamation-triangle-fill me-2"></i>Have I Been Pwned (HIBP) Breach Exposure</h5>
    <p class="mb-0"><strong>{{ hibp_breached }} accounts ({{ percent_hibp }}%)</strong> have passwords found in <strong>{{ "{:,}".format(hibp_total_exposures) }}</strong> data breaches.</p>
</div>
{% endif %}
{{ risk_explanation | safe }}

<div class="card shadow-sm mb-4">
    <div class="card-header {{ 'bg-danger' if risk_error else 'bg-primary' }} text-white">
        <h5 class="mb-0"><i class="bi bi-{{ 'exclamation-triangle' if risk_error else 'speedometer' }} me-2"></i>Risk Distribution</h5>
    </div>
    <div class="card-body">
    {% if risk_error %}{{ risk_error_html | safe }}{% else %}
    <p class="lead">Risk levels of the {{ cracked }} cracked passwords in {{ domain }}, assessed by length, complexity, and privilege.</p>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h6 class="text-muted">Overall Risk</h6>
                    <p class="display-6 mb-0">{{ risk_score_disp }}<small>/10.0</small></p>
                    <p class="mb-0">{{ overall_risk_badge | safe }}</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h6 class="text-muted">Average Score</h6>
                    <p class="display-6 mb-0">{{ avg_score_disp }}<small>/10.0</small></p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h6 class="text-muted">Maximum Score</h6>
                    <p class="display-6 mb-0">{{ max_score_disp }}<small>/10.0</small></p>
                </div>
            </div>
        </div>
    </div>

    <h5 class="mb-3">Distribution by Risk Level</h5>
    {{ risk_distribution_list_html | safe }}
    {% endif %}
    </div>
</div>
{{ risk_viz_html | safe }}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-{{ 'success' if (not da_error and not da_present) else 'danger' }} text-white">
        <h5 class="mb-0"><i class="bi bi-{{ 'exclamation-triangle' if da_error else ('diagram-3' if da_present else 'shield-check') }} me-2"></i>{{ 'BloodHound Insights' if da_error else 'BloodHound Insights - Domain Admin Pathways' }}</h5>
    </div>
    <div class="card-body">
    {% if da_error %}{{ da_error_html | safe }}
    {% elif da_present %}<div class="alert alert-danger" role="alert"><i class="bi bi-exclamation-triangle-fill me-2"></i><strong>{{ da_count }} cracked accounts</strong> have pathways to Domain Admin privileges in {{ domain }}.</div>
    {{ da_table_html | safe }}
    {% else %}<div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>No cracked accounts with DA pathways found.</div>
    {% endif %}
    </div>
</div>
{{ standard_viz_html | safe }}
{{ offcanvas_html | safe }}

{{ user_detail_script | safe }}
