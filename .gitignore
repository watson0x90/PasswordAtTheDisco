.ruff_cache/

# PyPI configuration file
.pypirc

# Project-specific ignores
# ========================

# HIBP password database - now tracked as git submodule
# The PwnedPasswordsDownloader is a submodule pointing to watson0x90/PwnedPasswordsDownloader
# Large data files inside it (*.txt, *.index*) are gitignored within the submodule itself
# Additional safety: ignore HIBP data files anywhere in the project
pwnedpasswords_ntlm.txt
pwnedpasswords_ntlm.txt.index*

# Generated reports and output
reports/
output/
test_html_output/

# Sample/audit input data -- contains real AD usernames from the lab; never commit
sample_data/

# Scripts directory (internal development only)
scripts/

# Ad-hoc dev test scripts in the repo root (the tracked suite lives in tests/)
/test_*.py
regenerate_html.py
alt_logo.txt

