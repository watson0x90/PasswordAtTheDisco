{# Autoescaped account/data tables. All {{ value }} interpolation of account
   fields (usernames, passwords, domains) is HTML-escaped by the environment,
   replacing the previous unescaped f-string table builders (server-side XSS). #}

{% macro risk_badge(level) -%}
{%- if not level or level == 'N/A' -%}<span class="badge bg-secondary">Unknown</span>
{%- elif (level|lower) in ['critical', 'high', 'medium', 'low'] -%}<span class="badge badge-risk-{{ level|lower }}">{{ level|title }}</span>
{%- else -%}<span class="badge bg-secondary">{{ level|title }}</span>
{%- endif -%}
{%- endmacro %}

{% macro _cell(value, kind) -%}
{%- if kind == 'user_link' -%}
<td><a href="#" class="user-detail-link text-decoration-none" data-username="{{ value }}" data-coreui-toggle="offcanvas" data-coreui-target="#userDetailOffcanvas"><code>{{ value }}</code></a></td>
{%- elif kind == 'code' -%}<td><code>{{ value }}</code></td>
{%- elif kind == 'risk_badge' -%}<td>{{ risk_badge(value) }}</td>
{%- elif kind == 'badge_warn' -%}<td><span class="badge bg-warning text-dark">{{ value }}</span></td>
{%- elif kind == 'badge_primary' -%}<td><span class="badge bg-primary">{{ value }}</span></td>
{%- elif kind == 'small_mono' -%}<td><small class="font-monospace">{{ value }}</small></td>
{%- elif kind == 'small' -%}<td><small>{{ value }}</small></td>
{%- else -%}<td>{{ value }}</td>
{%- endif -%}
{%- endmacro %}

{# columns: list of {header, field, kind}; rows: list of account dicts #}
{% macro account_table(columns, rows) -%}
<div class="table-responsive">
    <table class="table table-hover table-striped table-bordered">
        <thead class="table-dark"><tr>{% for c in columns %}<th scope="col">{{ c.header }}</th>{% endfor %}</tr></thead>
        <tbody>
{% for row in rows %}            <tr>{% for c in columns %}{{ _cell(row.get(c.field, 'N/A'), c.kind) }}{% endfor %}</tr>
{% endfor %}        </tbody>
    </table>
</div>
{%- endmacro %}

{# rows: list of {password, total, domain_counts: [(domain, count), ...]} #}
{% macro top_shared_passwords_table(rows) -%}
<div class="table-responsive">
    <table class="table table-hover table-striped table-bordered">
        <thead class="table-dark"><tr><th scope="col">Password</th><th scope="col">Total Accounts</th><th scope="col">Instances per Domain</th></tr></thead>
        <tbody>
{% for r in rows %}            <tr>
                <td><code>{{ r.password }}</code></td>
                <td><span class="badge bg-danger">{{ r.total }}</span></td>
                <td>{% for d, c in r.domain_counts %}<span class="badge bg-info">{{ d }}: {{ c }}</span>{% if not loop.last %}, {% endif %}{% endfor %}</td>
            </tr>
{% endfor %}        </tbody>
    </table>
</div>
{%- endmacro %}
