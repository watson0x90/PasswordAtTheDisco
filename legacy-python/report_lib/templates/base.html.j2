{# Base report layout. `head`, `navbar`, `sidebar` and `sidebar_nav_js` are
   trusted, pre-rendered chrome (passed through | safe). Page templates fill the
   `content` block, where {{ value }} interpolation is autoescaped. #}
{{ head | safe }}
<body>
    <a class="visually-hidden-focusable position-absolute top-0 start-0 m-2 btn btn-primary" href="#main-content">Skip to main content</a>
    <div class="wrapper">
        {{ navbar | safe }}

        <div class="body flex-grow-1">
            {{ sidebar | safe }}

            <!-- Main Content Area -->
            <main class="main-content" id="main-content">
                <div class="container-fluid p-4">
{% block content %}{% endblock %}
                </div>
            </main>
        </div>
    </div>

    {{ sidebar_nav_js | safe }}
{% block extra_scripts %}{% endblock %}
</body>
</html>
